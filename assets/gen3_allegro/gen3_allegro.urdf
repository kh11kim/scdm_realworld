      <geometry>
        <mesh filename="meshes/allegro/palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 3.14 1.57" xyz="0.02 -0.00 -0.1"/>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/allegro/palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
 <origin rpy="0 3.14 1.57" xyz="0.02 -0.00 -0.1"/>
    </collision>
